{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "lib": ["ESNext"],
    "strict": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "hive-shared/*": ["../src/shared/*"],
      "hive-telemetry": ["../src/telemetry.ts"],
      "hive-telemetry/*": ["../src/telemetry/*"],
      "hive-orchestrator": ["../src/orchestrator.ts"],
      "hive-orchestrator/*": ["../src/orchestrator/*"]
    }
  },
  "include": ["src/**/*.svelte", "src/**/*.ts"]
}
