{
  "name": "hive",
  "private": true,
  "scripts": {
    "dev:ui": "pnpm --filter ui dev",
    "dev:server": "pnpm --filter server dev",
    "dev": "pnpm run dev:server & pnpm run dev:ui",
    "build": "pnpm -r build",
    "test:dev-proxy": "node scripts/dev-proxy-smoke.mjs",
    "test": "pnpm run test:dev-proxy && pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "lefthook": "^2.1.9"
  }
}
