{
  "name": "hive",
  "version": "0.1.0",
  "description": "Lightweight local proxy daemon routing CLI agent traffic to free LLM providers",
  "type": "module",
  "bin": {
    "hive": "dist/main.js"
  },
  "scripts": {
    "hive": "node --import tsx --env-file=.env --watch src/main.ts",
    "ui": "vite",
    "dev": "npm run hive & npm run ui",
    "build:tsc": "tsc",
    "build:ui": "vite build",
    "build": "npm run build:tsc && npm run build:ui",
    "start": "node --env-file=.env dist/main.js",
    "test": "node --import tsx --env-file=.env --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@fastify/websocket": "^11.2.0",
    "@types/ws": "^8.18.1",
    "fastify": "^5.8.5",
    "http-proxy": "^1.18.1",
    "lru-cache": "^11.5.1",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fastify/vite": "^9.1.0",
    "@types/http-proxy": "^1.17.16",
    "@types/node": "^22.15.3",
    "eslint": "^10.5.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0"
  }
}
