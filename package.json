{
  "name": "hive",
  "version": "0.1.0",
  "description": "Lightweight local proxy daemon routing CLI agent traffic to free LLM providers",
  "type": "module",
  "bin": {
    "hive": "dist/hive.js"
  },
  "scripts": {
    "hive": "node --import tsx --env-file=.env --watch src/hive.ts",
    "ui": "vite",
    "dev": "npm run hive & npm run ui",
    "build": "tsc && vite build",
    "start": "node --env-file=.env dist/hive.js",
    "test": "node --import tsx --env-file=.env --test src/**/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "fastify": "^5.3.2",
    "http-proxy": "^1.18.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/http-proxy": "^1.17.16",
    "@types/node": "^22.15.3",
    "eslint": "^10.5.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.8.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0"
  }
}
